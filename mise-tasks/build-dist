#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# ///
#MISE description="Build the publishable single self-contained claude-sql wheel + sdist into dist/"
#MISE alias="build:dist"
"""Build the publishable ``claude-sql`` distribution as ONE self-contained wheel.

Why this exists (the workspace-split publish gap)
--------------------------------------------------
PR #60 split the codebase into five PEP 420 workspace members
(``packages/{core,analytics,evals,provenance,app}``), each its own
``claude-sql-*`` project sharing the ``claude_sql.*`` namespace. That is the
right *development* layout — editable members, independent test scoping, an
import-linter DAG. But it is the wrong *distribution* layout for this project:

* ``claude-sql`` on PyPI has always been a SINGLE bundled wheel. Its published
  1.0.1 ``Requires-Dist`` is the flattened third-party leaf set (anthropic,
  duckdb, polars, …) — it does NOT depend on ``claude-sql-core`` et al.
* The four member projects are NOT on PyPI (404). They were never meant to be
  separately published.
* ``uv build --package claude-sql`` therefore produces a broken wheel: it
  declares ``claude-sql-{core,analytics,evals,provenance}`` as runtime deps
  (wired only via dev-only ``[tool.uv.sources]``, which does not travel into
  published metadata), so ``pip install claude-sql`` cannot resolve them.

This task bridges the gap WITHOUT changing the dev workspace: it stages the
five ``packages/*/src/claude_sql/`` subtrees into one merged source tree, writes
a bundle ``pyproject.toml`` whose dependencies are the UNION of all members'
third-party deps (inter-member ``claude-sql-*`` deps dropped), and runs
``uv build`` on it. The result is exactly the single-wheel shape PyPI already
serves.

The version + dependency list are read from the member ``pyproject.toml`` files
at build time, so this never drifts from the source of truth.
"""

from __future__ import annotations

import shutil
import subprocess
import sys
import tomllib
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
MEMBERS = ["core", "analytics", "evals", "provenance", "app"]
# The app member owns the console-script entry point + user-facing metadata.
APP = "app"
STAGE = REPO / "build" / "bundle"
DIST = REPO / "dist"


def _load(member: str) -> dict:
    return tomllib.load((REPO / "packages" / member / "pyproject.toml").open("rb"))


def main() -> int:
    app_meta = _load(APP)["project"]
    version = app_meta["version"]

    # Union of every member's third-party deps; drop the inter-member
    # claude-sql-* deps (they are bundled into this same wheel, not resolved
    # from an index). Dedupe on the bare requirement string — all members pin
    # the same lower bounds via the shared lockfile, so duplicates are exact.
    deps: set[str] = set()
    for m in MEMBERS:
        for dep in _load(m)["project"].get("dependencies", []):
            if dep.startswith("claude-sql"):
                continue
            deps.add(dep)

    # Stage the five claude_sql.* subtrees into one merged namespace src tree.
    if STAGE.exists():
        shutil.rmtree(STAGE)
    pkg_dir = STAGE / "src" / "claude_sql"
    pkg_dir.mkdir(parents=True)
    for m in MEMBERS:
        src = REPO / "packages" / m / "src" / "claude_sql"
        for child in src.iterdir():
            dest = pkg_dir / child.name
            if dest.exists():
                # Two members must never own the same claude_sql.<sub> dir.
                raise SystemExit(f"bundle collision: {child.name} present in >1 member")
            if child.is_dir():
                shutil.copytree(child, dest)
            else:
                shutil.copy2(child, dest)

    shutil.copy2(REPO / "README.md", STAGE / "README.md")
    shutil.copy2(REPO / "LICENSE", STAGE / "LICENSE")

    # Carry the app's user-facing metadata (description, keywords, classifiers,
    # urls, license, entry point) verbatim; swap in the unioned deps and a
    # plain module-name (no inter-member sources).
    dep_lines = ",\n    ".join(f'"{d}"' for d in sorted(deps))
    keywords = ", ".join(f'"{k}"' for k in app_meta.get("keywords", []))
    classifiers = "".join(f'\n    "{c}",' for c in app_meta.get("classifiers", []))
    urls = app_meta.get("urls", {})
    url_lines = "\n".join(f'{k} = "{v}"' for k, v in urls.items())

    (STAGE / "pyproject.toml").write_text(
        f"""# GENERATED by mise-tasks/build-dist — do not edit. The source of truth is
# packages/*/pyproject.toml. This file bundles all five members into the one
# publishable ``claude-sql`` wheel. See the task docstring for why.
[project]
name = "claude-sql"
version = "{version}"
description = {app_meta["description"]!r}
readme = "README.md"
license = {{ text = "Apache-2.0" }}
authors = [{{ name = "Laith Al-Saadoon", email = "lalsaado@amazon.com" }}]
requires-python = "{app_meta["requires-python"]}"
keywords = [{keywords}]
classifiers = [{classifiers}
]
dependencies = [
    {dep_lines},
]

[project.scripts]
claude-sql = "claude_sql.app.cli:main"

[project.urls]
{url_lines}

[build-system]
requires = ["uv_build>=0.11.14,<0.12"]
build-backend = "uv_build"

[tool.uv.build-backend]
module-name = "claude_sql"
namespace = true
"""
    )

    DIST.mkdir(exist_ok=True)
    # Clear stale artifacts so dist/ holds exactly this build's wheel + sdist.
    for old in DIST.glob("claude_sql-*"):
        old.unlink()

    print(f"Building bundled claude-sql {version} from {len(MEMBERS)} members, {len(deps)} deps")
    subprocess.run(
        ["uv", "build", "--out-dir", str(DIST)],
        cwd=STAGE,
        check=True,
        env={**__import__("os").environ, "UV_LINK_MODE": "copy"},
    )
    built = sorted(p.name for p in DIST.glob("claude_sql-*"))
    print("Built:", ", ".join(built))
    return 0


if __name__ == "__main__":
    sys.exit(main())
